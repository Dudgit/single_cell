Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

%labels
    Author Bence
    Description PyTorch Lightning + Scanpy HPC environment

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/opt/conda/bin:$PATH
    
    # Force libraries to use the writable /tmp directory for caching
    export MPLCONFIGDIR=/tmp/matplotlib
    export NUMBA_CACHE_DIR=/tmp/numba

%post
    apt-get update && apt-get install -y \
        wget \
        git \
        build-essential \
        ca-certificates \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        && rm -rf /var/lib/apt/lists/*

    # upgrade pip
    python3 -m pip install --upgrade pip

    # install torch separately (GPU compatible)
    pip install --no-cache-dir torch>=2.0.0

    # install remaining packages
    pip install --no-cache-dir \
        pytorch-lightning>=2.0.0 \
        torchmetrics>=0.11.0 \
        omegaconf==2.3.0 \
        numpy>=1.24.0 \
        pandas>=1.5.0 \
        matplotlib>=3.7.0 \
        seaborn>=0.12.0 \
        umap-learn>=0.5.3 \
        anndata>=0.8.0 \
        scanpy>=1.9.0 \
        cell-gears \
        jupyterlab \
        ipykernel \

%runscript
    echo "Container ready. Python environment loaded."
    exec python3 "$@"
